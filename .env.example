# OpsCopilot 环境配置示例
# 复制此文件为 .env 并修改配置

# 数据库配置
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/ops_copilot?useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=Asia/Shanghai
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3.5:9B

# 监控系统配置 (可选)
MONITOR_ENABLED=false
MONITOR_API_URL=http://your-monitor-api
MONITOR_API_KEY=your-api-key

# CMDB配置 (可选)
CMDB_ENABLED=false
CMDB_API_URL=http://your-cmdb-api
CMDB_API_KEY=your-api-key

# 工单系统配置 (可选)
TICKET_ENABLED=false
TICKET_API_URL=http://your-ticket-api
TICKET_API_KEY=your-api-key

# 知识库向量搜索 (可选)
KNOWLEDGE_VECTOR_ENABLED=false
KNOWLEDGE_API_URL=http://your-knowledge-api
KNOWLEDGE_API_KEY=your-api-key
